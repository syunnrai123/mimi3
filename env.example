# 复制为 .env 或在系统环境变量中设置（不要提交 .env）

# 网关绑定地址与端口
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# 必需配置，Claw 节点连接的 WebSocket 桥接地址
WS_TUNNEL_URL=ws://your-domain.com:8000/ws

# WebSocket 节点接入密钥；不设则不对 /ws 节点接入鉴权
# 建议生产公网部署开启，并使用足够长的随机字符串
# MIMO_WS_TUNNEL_KEY=ws-your-random-secret-here

# Docker 本地持久化路径
MIMO_METRICS_DB_PATH=/app/data/gateway_metrics.db
MIMO_METRICS_SNAPSHOT_PATH=/app/data/gateway_snapshot.json
MIMO_PROCESS_LOCK_PATH=/app/data/mimo2api.lock

# 本机 OpenAI 兼容 /v1 的 Bearer 密钥（客户端 api_key）；不设则不对中转鉴权
# MIMO_RELAY_OPENAI_KEY=sk-your-random-secret-here

# WebUI 登录口令；不设则不启用 WebUI/API 管理面登录
# MIMO_WEBUI_USERNAME=admin
# MIMO_WEBUI_PASSWORD=change-me

# WebUI 会话签名密钥；不设时默认退化为使用上面的密码参与签名
# MIMO_WEBUI_SECRET=replace-with-a-long-random-string

# WebUI 会话有效期（秒），默认 43200，即 12 小时
# MIMO_WEBUI_SESSION_TTL_SECONDS=43200

# 仅在 HTTPS 反代后建议开启
# MIMO_WEBUI_COOKIE_SECURE=false
